---
import { PortableText } from '@portabletext/react';
import BaseHead from '../components/BaseHead.astro';
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';
import { getFAQs } from '../lib/sanity';
import type { FAQ } from '../lib/sanity';

const allFaqs = await getFAQs().catch(() => []);

// Group by category, preserving defined order
const categoryOrder = ['General', 'Sleep Consulting', 'Postpartum Doula', 'Pricing'] as const;

const grouped = categoryOrder.reduce<Record<string, FAQ[]>>((acc, cat) => {
	const items = allFaqs.filter((f) => f.category === cat);
	if (items.length > 0) acc[cat] = items;
	return acc;
}, {});

// Uncategorised FAQs land in their own group
const uncategorised = allFaqs.filter((f) => !f.category);
if (uncategorised.length > 0) grouped['Other'] = uncategorised;

const hasContent = allFaqs.length > 0;

// JSON-LD FAQ schema for SEO
const faqSchema = {
	'@context': 'https://schema.org',
	'@type': 'FAQPage',
	mainEntity: allFaqs.map((f) => ({
		'@type': 'Question',
		name: f.question,
		acceptedAnswer: {
			'@type': 'Answer',
			text: f.answer
				? f.answer
						.flatMap((block) =>
							block._type === 'block' && Array.isArray((block as any).children)
								? (block as any).children.map((span: { text?: string }) => span.text ?? '').join('')
								: [],
						)
						.join(' ')
				: '',
		},
	})),
};
---

<!doctype html>
<html lang="en">
	<head>
		<BaseHead
			title="FAQ — Little Wonder Care"
			description="Frequently asked questions about postpartum doula and gentle sleep consulting services from Little Wonder Care."
		/>
		{hasContent && (
			<script type="application/ld+json" is:inline set:html={JSON.stringify(faqSchema)} />
		)}
	</head>
	<body>
		<Header />

		<main>
			<div class="page-hero bg-crema">
				<p class="eyebrow">Have Questions?</p>
				<h1>Frequently Asked Questions</h1>
				<p class="subtitle">Everything you need to know before getting started. Can't find what you're looking for? Just <a href="/contact">send me a message</a>.</p>
			</div>

			<div class="section">
				<div class="faq-inner">
					{hasContent ? (
						Object.entries(grouped).map(([category, faqs]) => (
							<div class="faq-group">
								<h2 class="faq-category">{category}</h2>
								<div class="faq-list">
									{faqs.map((faq) => (
										<details class="faq-item" name={`faq-${category}`}>
											<summary class="faq-question">
												<span>{faq.question}</span>
												<span class="faq-icon" aria-hidden="true">+</span>
											</summary>
											<div class="faq-answer">
												{faq.answer && faq.answer.length > 0 ? (
													<PortableText value={faq.answer} />
												) : (
													<p>Answer coming soon.</p>
												)}
											</div>
										</details>
									))}
								</div>
							</div>
						))
					) : (
						<div class="faq-empty">
							<p>FAQs are being added. In the meantime, feel free to <a href="/contact">ask me directly</a>.</p>
						</div>
					)}
				</div>
			</div>

			<section class="cta-band">
				<h2>Still Have Questions?</h2>
				<p>I'm always happy to chat. Send me a message and I'll get back to you within 24 hours.</p>
				<a href="/contact" class="btn-cta-light">Get in Touch</a>
			</section>
		</main>

		<Footer />
	</body>
</html>

<style>
	main { width: 100%; max-width: 100%; margin: 0; padding: 0; }

	.faq-inner {
		max-width: 760px;
		margin: 0 auto;
	}

	/* Category heading */
	.faq-group { margin-bottom: 56px; }
	.faq-group:last-child { margin-bottom: 0; }

	.faq-category {
		font-family: var(--font-serif);
		font-size: 1.4rem;
		font-weight: 600;
		color: var(--teal-scuro);
		margin: 0 0 20px;
		padding-bottom: 12px;
		border-bottom: 2px solid rgba(183,201,206,0.4);
	}

	/* Accordion item */
	.faq-list { display: flex; flex-direction: column; gap: 2px; }

	.faq-item {
		background: #fff;
		border-radius: 12px;
		overflow: hidden;
		box-shadow: 0 1px 6px rgba(0,0,0,0.04);
		transition: box-shadow 0.2s;
	}

	.faq-item[open] { box-shadow: 0 4px 20px rgba(0,0,0,0.06); }

	/* Remove default triangle */
	.faq-question {
		list-style: none;
		display: flex;
		align-items: center;
		justify-content: space-between;
		gap: 16px;
		padding: 20px 24px;
		cursor: pointer;
		font-size: 0.97rem;
		font-weight: 600;
		color: var(--charcoal);
		line-height: 1.4;
		user-select: none;
		transition: background 0.15s;
	}

	.faq-question::-webkit-details-marker { display: none; }

	.faq-item[open] .faq-question { background: rgba(183,201,206,0.12); }
	.faq-question:hover { background: rgba(183,201,206,0.1); }

	.faq-icon {
		font-size: 1.3rem;
		font-weight: 300;
		color: var(--corallo);
		line-height: 1;
		transition: transform 0.25s;
		flex-shrink: 0;
	}

	.faq-item[open] .faq-icon { transform: rotate(45deg); }

	/* Answer */
	.faq-answer {
		padding: 0 24px 20px;
		font-size: 0.95rem;
		line-height: 1.75;
		color: rgba(45,45,45,0.75);
	}

	.faq-answer :global(p) { margin-bottom: 0.8em; }
	.faq-answer :global(p:last-child) { margin-bottom: 0; }

	.faq-answer :global(ul),
	.faq-answer :global(ol) { padding-left: 1.4em; margin-bottom: 0.8em; }

	.faq-answer :global(li) { margin-bottom: 0.3em; }

	.faq-answer :global(a) { color: var(--corallo); }
	.faq-answer :global(a:hover) { color: var(--pesca); }

	.faq-answer :global(strong) { color: var(--charcoal); font-weight: 600; }

	/* Empty state */
	.faq-empty {
		text-align: center;
		padding: 60px 24px;
		color: rgba(45,45,45,0.55);
		font-size: 1rem;
	}

	/* Hero link colour override */
	.page-hero a { color: var(--teal-medio); font-weight: 500; }
	.page-hero a:hover { color: var(--corallo); }
</style>
