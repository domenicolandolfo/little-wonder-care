---
import BaseHead from '../components/BaseHead.astro';
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';
---

<!doctype html>
<html lang="en">
	<head>
		<BaseHead
			title="Gentle Sleep Consulting — Little Wonder Care"
			description="Pediatric sleep consulting for newborns, infants, and toddlers. A gentle, respectful approach to help your whole family sleep better."
		/>
	</head>
	<body>
		<Header />

		<main>

			<!-- Page Hero -->
			<div class="page-hero bg-celeste">
				<p class="eyebrow">Pediatric Sleep Consulting</p>
				<h1>Better Sleep Starts Here</h1>
				<p class="subtitle">You're exhausted. Your baby is exhausted. It doesn't have to stay this way. I'll help your family sleep better — gently, respectfully, and at your own pace.</p>
			</div>

			<!-- Main Content -->
			<div class="section">
				<div class="content-section">

					<h2>My Approach</h2>
					<p>I believe every child can learn to sleep well — without crying it out, without rigid schedules, and without ignoring your instincts as a parent.</p>
					<p>My gentle approach is built around your child's temperament, your family's values, and the science of infant sleep. There's no one-size-fits-all plan. Every sleep plan I create is custom.</p>

					<h2>Ages I Work With</h2>
					<div class="ages-grid">
						<div class="age-card">
							<div class="age-emoji">🍼</div>
							<h4>Newborn</h4>
							<p>0–4 months</p>
						</div>
						<div class="age-card">
							<div class="age-emoji">👶</div>
							<h4>Infant</h4>
							<p>4–12 months</p>
						</div>
						<div class="age-card">
							<div class="age-emoji">🧸</div>
							<h4>Toddler</h4>
							<p>1–3 years</p>
						</div>
						<div class="age-card">
							<div class="age-emoji">🌙</div>
							<h4>Preschool</h4>
							<p>3–5 years</p>
						</div>
					</div>

					<h2>How It Works</h2>
					<p><strong>1. Intake questionnaire</strong> — Before we meet, you'll fill out a detailed form about your child's sleep habits, schedule, and your family's goals.</p>
					<p><strong>2. Consultation call</strong> — We meet via video to discuss everything in depth. I'll ask questions, listen, and start building your plan.</p>
					<p><strong>3. Custom sleep plan</strong> — Within 48 hours, you'll receive a detailed, step-by-step plan tailored to your child and your comfort level.</p>
					<p><strong>4. Ongoing support</strong> — For package clients, I'm with you daily for two weeks via text and email, plus follow-up calls to adjust the plan as needed.</p>

					<div class="highlight-box">
						<h2>Available Worldwide</h2>
						<p>All sleep consulting sessions are conducted via <strong>video call</strong>, so I can work with families anywhere in the <strong>United States and internationally</strong>.</p>
					</div>

					<div style="text-align: center; margin-top: 48px;">
						<a href="/services" class="btn-cta">View Packages &amp; Pricing</a>
						<p style="font-size:0.82rem; color:rgba(45,45,45,0.45); margin-top:12px; margin-bottom:0;">
							→ See all sleep consulting packages
						</p>
					</div>

				</div>
			</div>

			<!-- CTA Band -->
			<section class="cta-band">
				<h2>Ready for Better Nights?</h2>
				<p>A free 15-minute call is all it takes. Let's talk about your child's sleep and see how I can help.</p>
				<a href="/contact" class="btn-cta-light">Book a Free Discovery Call</a>
			</section>

		</main>

		<Footer />
	</body>
</html>

<style>
	main { width: 100%; max-width: 100%; margin: 0; padding: 0; }
</style>
