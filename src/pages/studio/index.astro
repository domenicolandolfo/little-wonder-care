---
// Handles the bare /studio and /studio/ paths in production on Vercel.
// The @sanity/astro integration injects a route for /studio/[...params] which
// only matches paths with content after the slash; this page catches the root.
// StudioComponent is client:only — the server renders the HTML shell and React
// mounts the full Sanity Studio on the client.
import { StudioComponent } from '@sanity/astro/studio/studio-component.tsx';

export const prerender = false;
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width,initial-scale=1,viewport-fit=cover" />
    <meta name="robots" content="noindex" />
    <link
      rel="icon"
      type="image/svg+xml"
      href="data:image/svg+xml,%3C%3Fxml version='1.0' encoding='utf-8'%3F%3E%3Csvg width='512' height='512' viewBox='0 0 512 512' fill='none' xmlns='http://www.w3.org/2000/svg'%3E%3Crect width='512' height='512' fill='%23F03E2F' rx='30' /%3E%3Cpath d='M161.527 136.723C161.527 179.76 187.738 205.443 240.388 219.095L296 232.283C345.687 243.852 376 272.275 376 319.514C376 341.727 369.162 360.931 357.538 375.971C357.538 329.232 333.607 303.78 276.171 288.74L221.47 276.246C177.709 266.065 143.977 242.464 143.977 191.56C143.977 170.505 150.359 151.994 161.527 136.723Z' fill='white' /%3E%3C/svg%3E"
    />
    <title>Sanity Studio — Little Wonder Care</title>
    <style>
      html, body { margin: 0; padding: 0; height: 100%; }
    </style>
  </head>
  <body>
    <StudioComponent client:only="react" />
  </body>
</html>
