---
import BaseHead from '../components/BaseHead.astro';
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';
---

<!doctype html>
<html lang="en">
	<head>
		<BaseHead
			title="Postpartum Doula — Little Wonder Care"
			description="Professional postpartum doula support in Waco, TX and online. Emotional care, newborn guidance, and hands-on help in the weeks after birth."
		/>
	</head>
	<body>
		<Header />

		<main>

			<!-- Page Hero -->
			<div class="page-hero bg-crema">
				<p class="eyebrow">Postpartum Doula · Waco, TX</p>
				<h1>You Don't Have to Do This Alone</h1>
				<p class="subtitle">A postpartum doula is the steady, experienced presence every new parent deserves — and very few know they can have.</p>
			</div>

			<!-- Main Content -->
			<div class="section">
				<div class="content-section">

					<h2>What Is a Postpartum Doula?</h2>
					<p>A postpartum doula is a trained professional who supports families during the weeks and months after birth. Unlike a night nurse or nanny, a doula cares for the whole family — not just the baby.</p>
					<p>I help with the emotional adjustment, answer the questions you didn't know you'd have, and provide hands-on support so you can rest, recover, and bond with your baby.</p>

					<div class="feature-grid">
						<div class="feature-item">
							<div class="feature-icon" style="background: var(--crema);">💛</div>
							<h3>Emotional Support</h3>
							<p>A listening ear, a calm presence, and reassurance that what you're feeling is completely normal.</p>
						</div>
						<div class="feature-item">
							<div class="feature-icon" style="background: var(--celeste);">👶</div>
							<h3>Newborn Care</h3>
							<p>Diapering, soothing, bathing, safe sleep — I'll help you feel confident with your baby.</p>
						</div>
						<div class="feature-item">
							<div class="feature-icon" style="background: var(--rosa-cipria);">🤱</div>
							<h3>Feeding Support</h3>
							<p>Whether breastfeeding, pumping, or bottle-feeding, I'll help you find what works for your family.</p>
						</div>
					</div>

					<h2>What to Expect</h2>
					<p>Every family is different, so we start with a prenatal visit to understand your needs, your values, and your vision for the postpartum period. After your baby arrives, I visit your home weekly to provide hands-on help and emotional support.</p>
					<p>My goal is simple: by the time our work together ends, you feel confident, rested, and connected to your baby.</p>

					<div class="highlight-box">
						<h2>Service Area</h2>
						<p>In-home visits are available in <strong>Waco, TX and surrounding areas</strong> (approximately 50-mile radius). Virtual postpartum support is available <strong>nationwide</strong>.</p>
					</div>

					<div style="text-align: center; margin-top: 48px;">
						<a href="/services" class="btn-cta">View Packages &amp; Pricing</a>
						<p style="font-size:0.82rem; color:rgba(45,45,45,0.45); margin-top:12px; margin-bottom:0;">
							→ See all postpartum support packages
						</p>
					</div>

				</div>
			</div>

			<!-- CTA Band -->
			<section class="cta-band">
				<h2>Wondering If a Doula Is Right for You?</h2>
				<p>Let's talk. A free 15-minute call is all it takes to see if we're a good fit.</p>
				<a href="/contact" class="btn-cta-light">Book a Free Discovery Call</a>
			</section>

		</main>

		<Footer />
	</body>
</html>

<style>
	main { width: 100%; max-width: 100%; margin: 0; padding: 0; }
</style>
