---
import BaseHead from '../components/BaseHead.astro';
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';
---

<!doctype html>
<html lang="en">
	<head>
		<BaseHead
			title="About Silvia — Little Wonder Care"
			description="Meet Silvia, DONA certified postpartum doula and gentle sleep coach based in Waco, TX. Supporting families with warmth, knowledge, and zero judgment."
		/>
	</head>
	<body>
		<Header />

		<main>

			<!-- About Hero — two-column grid -->
			<div class="section" style="padding-top: 64px;">
				<div class="about-hero-grid">
					<div class="about-photo-placeholder">
						<img src="/logo.jpg" alt="Silvia — Little Wonder Care" />
					</div>
					<div class="about-story">
						<p class="section-eyebrow" style="text-align:left;">About Me</p>
						<h2>Hi, I'm Silvia.</h2>
						<p>I know what it feels like to wake up at 3 a.m. wondering if you're doing everything wrong. I know the loneliness of those early weeks, when everyone says "enjoy every moment" but no one asks how you're really doing.</p>
						<p>That experience changed me. It's why I became a postpartum doula and sleep consultant — to be the calm, knowledgeable, judgment-free presence I wished I'd had.</p>
						<p>I believe that when a mother is supported, the whole family thrives. And I believe every baby can learn to sleep well, gently, when we understand their unique needs.</p>
						<a href="/contact" class="btn-cta" style="margin-top: 8px;">Book a Free Call</a>
					</div>
				</div>
			</div>

			<!-- Credentials -->
			<div class="section" style="background: var(--crema);">
				<div class="section-inner">
					<div class="section-header">
						<p class="section-eyebrow">Credentials</p>
						<h2 class="section-title">Training &amp; Certifications</h2>
					</div>
					<div class="credentials-grid">
						<div class="credential-card">
							<div class="cred-icon">📜</div>
							<h3>DONA Certified</h3>
							<p>Certified Postpartum Doula through DONA International, the gold standard in doula certification.</p>
						</div>
						<div class="credential-card">
							<div class="cred-icon">🌙</div>
							<h3>GSC Program Certified</h3>
							<p>Certified Gentle Sleep Coach, trained in evidence-based, attachment-friendly sleep methods.</p>
						</div>
						<div class="credential-card">
							<div class="cred-icon">📚</div>
							<h3>Continuing Education</h3>
							<p>I invest in ongoing training to stay current with the latest research in infant sleep and postpartum care.</p>
						</div>
					</div>
				</div>
			</div>

			<!-- Values -->
			<div class="section">
				<div class="section-inner">
					<div class="section-header">
						<p class="section-eyebrow">What I Believe</p>
						<h2 class="section-title">My Values</h2>
					</div>
					<div class="values-grid">
						<div class="value-item">
							<div class="value-dot"></div>
							<div>
								<h4>No Judgment, Ever</h4>
								<p>However you feed, sleep, or parent your baby — I'm here to support you, not to judge.</p>
							</div>
						</div>
						<div class="value-item">
							<div class="value-dot"></div>
							<div>
								<h4>Gentle &amp; Respectful</h4>
								<p>My methods honor your baby's developmental needs and your instincts as a parent.</p>
							</div>
						</div>
						<div class="value-item">
							<div class="value-dot"></div>
							<div>
								<h4>Evidence-Based</h4>
								<p>Everything I recommend is grounded in current research and best practices.</p>
							</div>
						</div>
						<div class="value-item">
							<div class="value-dot"></div>
							<div>
								<h4>You Know Your Baby Best</h4>
								<p>I'm here to guide, not to prescribe. You always have the final say.</p>
							</div>
						</div>
					</div>
				</div>
			</div>

			<!-- CTA Band -->
			<section class="cta-band">
				<h2>Let's Work Together</h2>
				<p>I'd love to hear your story. Book a free call and let's talk about how I can support your family.</p>
				<a href="/contact" class="btn-cta-light">Book a Free Discovery Call</a>
			</section>

		</main>

		<Footer />
	</body>
</html>

<style>
	main { width: 100%; max-width: 100%; margin: 0; padding: 0; }
</style>
