---
import BaseHead from '../components/BaseHead.astro';
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';
import { getTestimonials, urlFor } from '../lib/sanity';

const testimonials = await getTestimonials().catch(() => []);

const categories = ['All', 'Sleep Consulting', 'Postpartum Doula'] as const;
---

<!doctype html>
<html lang="en">
	<head>
		<BaseHead
			title="Testimonials — Little Wonder Care"
			description="Real stories from families who have worked with Little Wonder Care for postpartum doula and sleep consulting support."
		/>
	</head>
	<body>
		<Header />

		<main>
			<div class="page-hero bg-rosa">
				<p class="eyebrow">Families I've Worked With</p>
				<h1>Real Stories</h1>
				<p class="subtitle">Every family is different. Here's what some of them have shared about working together.</p>
			</div>

			<div class="section">
				<div class="section-inner">

					{testimonials.length > 0 ? (
						<>
							<!-- Filter buttons -->
							<div class="filter-bar" role="group" aria-label="Filter by service type">
								{categories.map((cat) => (
									<button
										class={`filter-btn${cat === 'All' ? ' active' : ''}`}
										data-filter={cat}
									>
										{cat}
									</button>
								))}
							</div>

							<!-- Grid -->
							<div class="t-grid" id="testimonials-grid">
								{testimonials.map((t) => (
									<article
										class="t-card"
										data-service={t.serviceType ?? 'All'}
									>
										<div class="t-card-top">
											{t.photo?.asset ? (
												<img
													class="t-avatar"
													src={urlFor(t.photo).width(80).height(80).fit('crop').auto('format').url()}
													alt={t.photo.alt ?? t.name}
													width="80"
													height="80"
												/>
											) : (
												<div class="t-avatar-initial" aria-hidden="true">
													{t.name.charAt(0).toUpperCase()}
												</div>
											)}
											<div>
												<p class="t-name">{t.name}</p>
												{(t.serviceType || t.childAge) && (
													<p class="t-meta">
														{[t.serviceType, t.childAge].filter(Boolean).join(' · ')}
													</p>
												)}
											</div>
										</div>

										{t.rating && t.rating > 0 && (
											<div class="t-stars" aria-label={`${t.rating} out of 5 stars`}>
												{'★'.repeat(t.rating)}{'☆'.repeat(5 - t.rating)}
											</div>
										)}

										<p class="t-quote">"{t.quote}"</p>
									</article>
								))}
							</div>

							<p class="t-no-results" id="no-results" aria-live="polite" hidden>
								No testimonials in this category yet.
							</p>
						</>
					) : (
						<div class="t-empty">
							<p>Testimonials are coming soon. In the meantime, feel free to <a href="/contact">get in touch</a>.</p>
						</div>
					)}

				</div>
			</div>

			<section class="cta-band">
				<h2>Ready to Start Your Own Story?</h2>
				<p>Book a free discovery call and let's talk about how I can support your family.</p>
				<a href="/contact" class="btn-cta-light">Book a Free Discovery Call</a>
			</section>
		</main>

		<Footer />
	</body>
</html>

<script>
	const buttons = document.querySelectorAll<HTMLButtonElement>('.filter-btn');
	const cards = document.querySelectorAll<HTMLElement>('.t-card');
	const noResults = document.getElementById('no-results');

	buttons.forEach((btn) => {
		btn.addEventListener('click', () => {
			const filter = btn.dataset.filter ?? 'All';

			// Update active state
			buttons.forEach((b) => b.classList.remove('active'));
			btn.classList.add('active');

			// Show/hide cards
			let visible = 0;
			cards.forEach((card) => {
				const matches = filter === 'All' || card.dataset.service === filter;
				card.hidden = !matches;
				if (matches) visible++;
			});

			if (noResults) noResults.hidden = visible > 0;
		});
	});
</script>

<style>
	main { width: 100%; max-width: 100%; margin: 0; padding: 0; }

	/* Filter bar */
	.filter-bar {
		display: flex;
		gap: 10px;
		margin-bottom: 40px;
		flex-wrap: wrap;
	}

	.filter-btn {
		padding: 8px 20px;
		border-radius: 50px;
		border: 2px solid rgba(183,201,206,0.5);
		background: transparent;
		font-size: 0.82rem;
		font-weight: 500;
		font-family: var(--font-sans);
		color: var(--teal-medio);
		cursor: pointer;
		transition: all 0.2s;
		letter-spacing: 0.02em;
	}

	.filter-btn:hover { border-color: var(--corallo); color: var(--corallo); }

	.filter-btn.active {
		background: var(--corallo);
		border-color: var(--corallo);
		color: #fff;
	}

	/* Testimonial grid */
	.t-grid {
		display: grid;
		grid-template-columns: repeat(auto-fill, minmax(300px, 1fr));
		gap: 24px;
	}

	.t-card {
		background: #fff;
		border-radius: 20px;
		padding: 32px 28px;
		box-shadow: 0 2px 16px rgba(0,0,0,0.04);
		display: flex;
		flex-direction: column;
		gap: 16px;
		transition: transform 0.2s, box-shadow 0.2s;
	}

	.t-card:hover {
		transform: translateY(-3px);
		box-shadow: 0 8px 28px rgba(0,0,0,0.07);
	}

	.t-card-top {
		display: flex;
		align-items: center;
		gap: 14px;
	}

	.t-avatar {
		width: 48px;
		height: 48px;
		border-radius: 50%;
		object-fit: cover;
		flex-shrink: 0;
		border-radius: 50% !important;
	}

	.t-avatar-initial {
		width: 48px;
		height: 48px;
		border-radius: 50%;
		background: var(--rosa-cipria);
		color: var(--rosa-scuro);
		font-family: var(--font-serif);
		font-size: 1.3rem;
		font-weight: 600;
		display: flex;
		align-items: center;
		justify-content: center;
		flex-shrink: 0;
	}

	.t-name {
		font-family: var(--font-serif);
		font-size: 1.05rem;
		font-weight: 600;
		color: var(--charcoal);
		margin: 0;
	}

	.t-meta {
		font-size: 0.75rem;
		color: var(--teal-chiaro);
		margin: 2px 0 0;
		text-transform: uppercase;
		letter-spacing: 0.06em;
	}

	.t-stars {
		font-size: 0.95rem;
		color: var(--corallo);
		letter-spacing: 0.05em;
	}

	.t-quote {
		font-family: var(--font-serif);
		font-size: 1.05rem;
		font-style: italic;
		line-height: 1.7;
		color: rgba(45,45,45,0.8);
		margin: 0;
		flex: 1;
	}

	.t-no-results {
		text-align: center;
		color: rgba(45,45,45,0.5);
		font-size: 0.95rem;
		padding: 40px 0;
	}

	.t-empty {
		text-align: center;
		padding: 60px 24px;
		color: rgba(45,45,45,0.55);
		font-size: 1rem;
	}

	@media (max-width: 560px) {
		.t-grid { grid-template-columns: 1fr; }
	}
</style>
