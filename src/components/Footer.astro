---
---

<footer class="footer">
	<div class="footer-inner">
		<div class="footer-left">
			<img src="/logo.jpg" alt="Little Wonder Care" width="36" height="36" />
			<span>Little Wonder Care</span>
		</div>
		<div class="footer-right">
			<div class="footer-social">
				<a href="#" aria-label="Instagram">
					<svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
						<rect x="2" y="2" width="20" height="20" rx="5"/>
						<circle cx="12" cy="12" r="5"/>
						<circle cx="17.5" cy="6.5" r="1.5" fill="currentColor" stroke="none"/>
					</svg>
				</a>
				<a href="#" aria-label="Facebook">
					<svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
						<path d="M18 2h-3a5 5 0 0 0-5 5v3H7v4h3v8h4v-8h3l1-4h-4V7a1 1 0 0 1 1-1h3z"/>
					</svg>
				</a>
				<a href="#" aria-label="Email">
					<svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
						<rect x="2" y="4" width="20" height="16" rx="2"/>
						<path d="m22 7-8.97 5.7a1.94 1.94 0 0 1-2.06 0L2 7"/>
					</svg>
				</a>
			</div>
			<a href="/contact">Contact</a>
			<a href="/privacy-policy">Privacy Policy</a>
			<span>© 2026 Little Wonder Care</span>
		</div>
	</div>
</footer>

<style>
	.footer {
		background: #ede8de;
		padding: 40px 24px;
		border-top: 1px solid rgba(183, 201, 206, 0.2);
	}

	.footer-inner {
		max-width: 1100px;
		margin: 0 auto;
		display: flex;
		align-items: center;
		justify-content: space-between;
		flex-wrap: wrap;
		gap: 20px;
	}

	.footer-left {
		display: flex;
		align-items: center;
		gap: 12px;
	}

	.footer-left img {
		width: 36px;
		height: 36px;
		border-radius: 50%;
		object-fit: cover;
	}

	.footer-left span {
		font-family: 'Cormorant Garamond', Georgia, serif;
		font-size: 1.1rem;
		font-weight: 600;
		color: #5a7a82;
	}

	.footer-right {
		display: flex;
		align-items: center;
		gap: 24px;
		font-size: 0.8rem;
		color: rgba(45, 45, 45, 0.55);
		flex-wrap: wrap;
	}

	.footer-right a {
		color: rgba(45, 45, 45, 0.55);
		text-decoration: none;
		transition: color 0.2s;
	}

	.footer-right a:hover { color: #cc806b; }

	.footer-social {
		display: flex;
		gap: 10px;
	}

	.footer-social a {
		width: 36px;
		height: 36px;
		border-radius: 50%;
		background: rgba(90, 122, 130, 0.08);
		display: flex;
		align-items: center;
		justify-content: center;
		color: #5a7a82;
		transition: background 0.2s;
	}

	.footer-social a:hover { background: rgba(90, 122, 130, 0.18); }

	@media (max-width: 600px) {
		.footer-inner { flex-direction: column; text-align: center; }
		.footer-right { justify-content: center; }
	}
</style>
