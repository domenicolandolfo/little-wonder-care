---
const navLinks = [
	{ href: '/', label: 'Home' },
	{ href: '/postpartum-doula', label: 'Postpartum Doula' },
	{ href: '/sleep-consulting', label: 'Sleep Consulting' },
	{ href: '/services', label: 'Services' },
	{ href: '/about', label: 'About' },
	{ href: '/blog', label: 'Blog' },
	{ href: '/contact', label: 'Contact' },
];

const currentPath = Astro.url.pathname;
---

<header class="bg-[#FAF9F6] border-b border-[#9CAF88]/40 sticky top-0 z-50 shadow-sm">
	<div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
		<div class="flex items-center justify-between h-16">

			<!-- Logo -->
			<a
				href="/"
				class="text-[#2D2D2D] font-bold text-lg sm:text-xl tracking-tight hover:text-[#9CAF88] transition-colors duration-200 shrink-0"
			>
				Little Wonder Care
			</a>

			<!-- Desktop Navigation -->
			<nav class="hidden lg:flex items-center gap-0.5" aria-label="Main navigation">
				{navLinks.map(({ href, label }) => (
					<a
						href={href}
						class={`px-3 py-2 text-sm font-medium rounded-md transition-colors duration-200 whitespace-nowrap ${
							currentPath === href || (href !== '/' && currentPath.startsWith(href))
								? 'text-[#9CAF88] bg-[#9CAF88]/10'
								: 'text-[#2D2D2D] hover:text-[#9CAF88] hover:bg-[#9CAF88]/10'
						}`}
					>
						{label}
					</a>
				))}
			</nav>

			<!-- Hamburger Button -->
			<button
				id="hamburger-btn"
				class="lg:hidden p-2 rounded-md text-[#2D2D2D] hover:text-[#9CAF88] hover:bg-[#9CAF88]/10 transition-colors duration-200"
				aria-label="Open navigation menu"
				aria-expanded="false"
				aria-controls="mobile-menu"
			>
				<!-- Menu icon -->
				<svg
					id="menu-icon"
					class="w-6 h-6"
					fill="none"
					stroke="currentColor"
					viewBox="0 0 24 24"
					aria-hidden="true"
				>
					<path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M4 6h16M4 12h16M4 18h16" />
				</svg>
				<!-- Close icon -->
				<svg
					id="close-icon"
					class="w-6 h-6 hidden"
					fill="none"
					stroke="currentColor"
					viewBox="0 0 24 24"
					aria-hidden="true"
				>
					<path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M6 18L18 6M6 6l12 12" />
				</svg>
			</button>
		</div>
	</div>

	<!-- Mobile Menu -->
	<div
		id="mobile-menu"
		class="hidden lg:hidden bg-[#FAF9F6] border-t border-[#9CAF88]/30"
		aria-label="Mobile navigation"
	>
		<nav class="max-w-7xl mx-auto px-4 py-3 flex flex-col gap-0.5">
			{navLinks.map(({ href, label }) => (
				<a
					href={href}
					class={`px-3 py-2.5 text-sm font-medium rounded-md transition-colors duration-200 ${
						currentPath === href || (href !== '/' && currentPath.startsWith(href))
							? 'text-[#9CAF88] bg-[#9CAF88]/10'
							: 'text-[#2D2D2D] hover:text-[#9CAF88] hover:bg-[#9CAF88]/10'
					}`}
				>
					{label}
				</a>
			))}
		</nav>
	</div>
</header>

<script>
	const btn = document.getElementById('hamburger-btn');
	const menu = document.getElementById('mobile-menu');
	const menuIcon = document.getElementById('menu-icon');
	const closeIcon = document.getElementById('close-icon');

	btn?.addEventListener('click', () => {
		const isOpen = !menu?.classList.contains('hidden');
		menu?.classList.toggle('hidden', isOpen);
		menuIcon?.classList.toggle('hidden', !isOpen);
		closeIcon?.classList.toggle('hidden', isOpen);
		btn.setAttribute('aria-expanded', String(!isOpen));
		btn.setAttribute('aria-label', isOpen ? 'Open navigation menu' : 'Close navigation menu');
	});
</script>
