---
const serviceLinks = [
	{ href: '/services', label: 'All Services' },
	{ href: '/postpartum-doula', label: 'Postpartum Doula' },
	{ href: '/sleep-consulting', label: 'Sleep Consulting' },
];

const navLinks = [
	{ href: '/about', label: 'About' },
	{ href: '/blog', label: 'Blog' },
];

const currentPath = Astro.url.pathname;
const servicesActive = serviceLinks.some(l => currentPath === l.href || (l.href !== '/' && currentPath.startsWith(l.href)));
---

<nav class="navbar">
	<div class="navbar-inner">
		<!-- Logo -->
		<a href="/" class="navbar-logo">
			<img src="/logo.jpg" alt="Little Wonder Care logo" width="48" height="48" />
			<span>Little Wonder Care</span>
		</a>

		<!-- Desktop links -->
		<ul class="navbar-links">
			<!-- Services dropdown -->
			<li class="has-dropdown">
				<button class={`dropdown-trigger${servicesActive ? ' active' : ''}`} aria-expanded="false" aria-haspopup="true">
					Services
					<svg class="chevron" width="12" height="12" viewBox="0 0 12 12" fill="none" aria-hidden="true">
						<path d="M2 4l4 4 4-4" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"/>
					</svg>
				</button>
				<ul class="dropdown-menu" role="menu">
					{serviceLinks.map(({ href, label }) => (
						<li role="none">
							<a href={href} role="menuitem"
								class={currentPath === href || (href !== '/services' && currentPath.startsWith(href)) ? 'active' : ''}>
								{label}
							</a>
						</li>
					))}
				</ul>
			</li>
			{navLinks.map(({ href, label }) => (
				<li>
					<a
						href={href}
						class={currentPath === href || (href !== '/' && currentPath.startsWith(href)) ? 'active' : ''}
					>
						{label}
					</a>
				</li>
			))}
			<li><a href="/contact" data-cal-link="littlewondercare/discovery-call" data-cal-namespace="" class="navbar-cta">Book Now</a></li>
		</ul>

		<!-- Hamburger -->
		<button class="menu-toggle" id="menu-toggle" aria-label="Open menu" aria-expanded="false">
			<span></span>
			<span></span>
			<span></span>
		</button>
	</div>

	<!-- Mobile drawer -->
	<div class="mobile-menu" id="mobile-menu" aria-hidden="true">
		<ul>
			<!-- Services expandable -->
			<li class="mobile-has-dropdown">
				<button class={`mobile-dropdown-trigger${servicesActive ? ' active' : ''}`} aria-expanded="false">
					Services
					<svg class="chevron" width="12" height="12" viewBox="0 0 12 12" fill="none" aria-hidden="true">
						<path d="M2 4l4 4 4-4" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"/>
					</svg>
				</button>
				<ul class="mobile-dropdown">
					{serviceLinks.map(({ href, label }) => (
						<li><a href={href}>{label}</a></li>
					))}
				</ul>
			</li>
			{navLinks.map(({ href, label }) => (
				<li><a href={href}>{label}</a></li>
			))}
			<li><a href="/contact" data-cal-link="littlewondercare/discovery-call" data-cal-namespace="" class="navbar-cta">Book Now</a></li>
		</ul>
	</div>
</nav>

<style>
	.navbar {
		background: #ede8de;
		border-bottom: 1px solid rgba(92, 74, 42, 0.08);
		padding: 0 24px;
		position: sticky;
		top: 0;
		z-index: 100;
	}

	.navbar-inner {
		max-width: 1100px;
		margin: 0 auto;
		display: flex;
		align-items: center;
		justify-content: space-between;
		height: 72px;
	}

	.navbar-logo {
		display: flex;
		align-items: center;
		gap: 12px;
		text-decoration: none;
	}

	.navbar-logo img {
		width: 48px;
		height: 48px;
		border-radius: 50%;
		object-fit: cover;
	}

	.navbar-logo span {
		font-family: 'Cormorant Garamond', Georgia, serif;
		font-size: 1.35rem;
		font-weight: 600;
		color: #5a7a82;
		letter-spacing: -0.01em;
	}

	/* ── Desktop nav ── */
	.navbar-links {
		display: flex;
		align-items: center;
		gap: 32px;
		list-style: none;
		margin: 0;
		padding: 0;
	}

	.navbar-links a,
	.dropdown-trigger {
		text-decoration: none;
		font-size: 0.78rem;
		font-weight: 500;
		text-transform: uppercase;
		letter-spacing: 0.08em;
		color: #5c4a2a;
		transition: color 0.2s;
		background: none;
		border: none;
		cursor: pointer;
		padding: 0;
		font-family: inherit;
		display: flex;
		align-items: center;
		gap: 4px;
	}

	.navbar-links a:hover,
	.navbar-links a.active,
	.dropdown-trigger:hover,
	.dropdown-trigger.active { color: #cc806b; }

	.navbar-cta {
		background: #cc806b !important;
		color: #fff !important;
		padding: 10px 24px;
		border-radius: 50px;
		font-size: 0.82rem !important;
		font-weight: 600 !important;
		letter-spacing: 0.04em !important;
		transition: background 0.2s, transform 0.15s !important;
	}

	.navbar-cta:hover {
		background: #e89984 !important;
		transform: translateY(-1px);
	}

	/* ── Dropdown ── */
	.has-dropdown {
		position: relative;
	}

	.chevron {
		transition: transform 0.2s;
		flex-shrink: 0;
	}

	.dropdown-trigger[aria-expanded="true"] .chevron {
		transform: rotate(180deg);
	}

	.dropdown-menu {
		position: absolute;
		top: calc(100% + 12px);
		left: 50%;
		transform: translateX(-50%);
		min-width: 200px;
		background: #ede8de;
		border: 1px solid rgba(92, 74, 42, 0.1);
		border-radius: 10px;
		box-shadow: 0 8px 24px rgba(92, 74, 42, 0.12);
		list-style: none;
		margin: 0;
		padding: 6px;
		opacity: 0;
		visibility: hidden;
		transform: translateX(-50%) translateY(-6px);
		transition: opacity 0.18s, transform 0.18s, visibility 0.18s;
		pointer-events: none;
	}

	.has-dropdown:hover .dropdown-menu,
	.has-dropdown:focus-within .dropdown-menu,
	.dropdown-trigger[aria-expanded="true"] ~ .dropdown-menu {
		opacity: 1;
		visibility: visible;
		transform: translateX(-50%) translateY(0);
		pointer-events: auto;
	}

	.dropdown-menu a {
		display: block;
		padding: 9px 14px;
		border-radius: 6px;
		font-size: 0.78rem;
		font-weight: 500;
		text-transform: uppercase;
		letter-spacing: 0.06em;
		color: #5c4a2a;
		text-decoration: none;
		transition: background 0.15s, color 0.15s;
		white-space: nowrap;
	}

	.dropdown-menu a:hover,
	.dropdown-menu a.active {
		background: rgba(204, 128, 107, 0.1);
		color: #cc806b;
	}

	/* ── Hamburger ── */
	.menu-toggle {
		display: none;
		background: none;
		border: none;
		cursor: pointer;
		padding: 8px;
	}

	.menu-toggle span {
		display: block;
		width: 24px;
		height: 2px;
		background: #5a7a82;
		margin: 5px 0;
		border-radius: 2px;
		transition: 0.3s;
	}

	/* ── Mobile drawer ── */
	.mobile-menu {
		display: none;
		background: #ede8de;
		border-top: 1px solid rgba(92, 74, 42, 0.08);
		padding: 16px 24px 24px;
	}

	.mobile-menu.open { display: block; }

	.mobile-menu > ul {
		list-style: none;
		margin: 0 auto;
		padding: 0;
		display: flex;
		flex-direction: column;
		gap: 4px;
		max-width: 1100px;
	}

	.mobile-menu a {
		display: block;
		padding: 10px 12px;
		text-decoration: none;
		font-size: 0.85rem;
		font-weight: 500;
		text-transform: uppercase;
		letter-spacing: 0.08em;
		color: #5c4a2a;
		border-radius: 8px;
		transition: background 0.2s, color 0.2s;
	}

	.mobile-menu a:hover { background: rgba(204, 128, 107, 0.08); color: #cc806b; }

	.mobile-menu .navbar-cta {
		margin-top: 8px;
		display: inline-block;
		padding: 10px 24px !important;
	}

	/* Mobile Services expandable */
	.mobile-dropdown-trigger {
		display: flex;
		align-items: center;
		gap: 6px;
		width: 100%;
		background: none;
		border: none;
		cursor: pointer;
		padding: 10px 12px;
		font-size: 0.85rem;
		font-weight: 500;
		text-transform: uppercase;
		letter-spacing: 0.08em;
		color: #5c4a2a;
		border-radius: 8px;
		font-family: inherit;
		transition: background 0.2s, color 0.2s;
	}

	.mobile-dropdown-trigger:hover,
	.mobile-dropdown-trigger.active { background: rgba(204, 128, 107, 0.08); color: #cc806b; }

	.mobile-dropdown-trigger[aria-expanded="true"] .chevron { transform: rotate(180deg); }

	.mobile-dropdown {
		list-style: none;
		margin: 2px 0 0;
		padding: 0 0 0 16px;
		display: none;
	}

	.mobile-dropdown.open { display: block; }

	.mobile-dropdown a {
		font-size: 0.8rem;
		padding: 8px 12px;
		color: #5c4a2a;
	}

	@media (max-width: 900px) {
		.navbar-links { display: none; }
		.menu-toggle { display: block; }
		.navbar-inner { height: 60px; }
		.navbar-logo span { font-size: 1.15rem; }
	}
</style>

<script>
	// Hamburger toggle
	const toggle = document.getElementById('menu-toggle');
	const menu = document.getElementById('mobile-menu');

	toggle?.addEventListener('click', () => {
		const isOpen = menu?.classList.contains('open');
		menu?.classList.toggle('open', !isOpen);
		toggle.setAttribute('aria-expanded', String(!isOpen));
		toggle.setAttribute('aria-label', isOpen ? 'Open menu' : 'Close menu');
	});

	// Desktop dropdown: toggle on click (for keyboard/touch)
	const desktopTrigger = document.querySelector<HTMLButtonElement>('.dropdown-trigger');
	const desktopDropdown = document.querySelector<HTMLElement>('.dropdown-menu');

	desktopTrigger?.addEventListener('click', () => {
		const expanded = desktopTrigger.getAttribute('aria-expanded') === 'true';
		desktopTrigger.setAttribute('aria-expanded', String(!expanded));
	});

	// Close desktop dropdown when clicking outside
	document.addEventListener('click', (e) => {
		if (desktopTrigger && desktopDropdown && !desktopTrigger.closest('.has-dropdown')?.contains(e.target as Node)) {
			desktopTrigger.setAttribute('aria-expanded', 'false');
		}
	});

	// Mobile Services expandable
	const mobileTrigger = document.querySelector<HTMLButtonElement>('.mobile-dropdown-trigger');
	const mobileDropdown = document.querySelector<HTMLElement>('.mobile-dropdown');

	mobileTrigger?.addEventListener('click', () => {
		const expanded = mobileTrigger.getAttribute('aria-expanded') === 'true';
		mobileTrigger.setAttribute('aria-expanded', String(!expanded));
		mobileDropdown?.classList.toggle('open', !expanded);
	});
</script>
